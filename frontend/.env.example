# ── Stock Chart Helper Frontend — environment variables ──────────────────────
# Copy to .env.local for local overrides (never commit .env.local).

# Backend API base URL for PRODUCTION deployments.
# In development this is NOT needed — the Vite dev server proxies /api → http://127.0.0.1:8001.
# On Vercel (or any static host), set this to your deployed backend URL.
#   e.g. https://stock-chart-helper-api.onrender.com
# Leave blank to keep the /api proxy behaviour (dev only).
VITE_API_BASE_URL=
