# ===================================================
# 로컬 데스크톱 모드 — Render/Vercel 없이 내 컴퓨터에서만 실행할 때 사용
# 사용법: 이 파일을 backend/.env 로 복사한 뒤 필요하면 값 수정
#   cp backend/.env.local.example backend/.env
# ===================================================

# SQLite — 파일 하나로 끝나는 로컬 DB. Postgres 서버를 따로 띄울 필요 없음.
# backend/data/ 디렉터리가 없으면 앱 시작 시 자동 생성된다.
DATABASE_URL=sqlite+aiosqlite:///./data/local.db

# Redis를 비워두면 앱이 자동으로 메모리 캐시로 대체한다(app/core/redis.py의
# 기존 폴백 동작 — Redis 서버가 없어도 동작에는 문제없다. 다만 앱을 재시작하면
# 캐시가 초기화된다).
REDIS_URL=

SECRET_KEY=local-desktop-mode-not-for-production
DEBUG=true
DEPLOYMENT_PLATFORM=local
ENABLE_PLATFORM_KEEPALIVE=false

# ===================================================
# 자동 스캔/관심종목 알림 — 로컬 모드에서는 끈다
# ===================================================
# 상시 서버에서만 의미 있는 하루 4번 자동 스캔, 10분마다 관심종목 알림,
# 주간 백테스트/정비 잡을 전부 끈다. 앱을 켤 때(시작 스캔)와 화면의
# "새로고침" 버튼으로 필요할 때만 갱신한다.
ENABLE_SCHEDULER=false
# 앱을 켤 때는 한 번 스캔해서 화면에 바로 데이터가 보이게 한다 (원치 않으면 false).
STARTUP_DAILY_SCAN_ENABLED=true

# ===================================================
# CORS — 로컬 프론트엔드 주소
# ===================================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===================================================
# KIS / 토스증권 실시간 시세 API — 선택사항, 있으면 채워 넣기
# ===================================================
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=
# TOSS_CLIENT_ID=
# TOSS_CLIENT_SECRET=

# ===================================================
# 텔레그램 알림 — 로컬 모드에서는 관심종목 자동 체크 자체를 안 하므로 보통 불필요
# ===================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ===================================================
# OpenAI API — 선택사항 (AI 추천 코멘터리)
# ===================================================
# OPENAI_API_KEY=
